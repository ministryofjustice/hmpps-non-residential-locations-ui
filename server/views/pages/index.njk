{% extends "../partials/layout.njk" %}

{% from "../macros/locationsTable.njk" import locationsTable %}
{% from "../partials/simplePagination/macro.njk" import simplePagination %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}

{% set mainClasses =
  "app-container govuk-body" ~ (" govuk-!-padding-top-0" if mojBanner else "")
%}

{% block content %}
  <h1>{{ title }}</h1>
  <div class="{{ mainClasses }}">

    {% if canEdit %}
      <a class="govuk-button govuk-button--secondary govuk-!-margin-bottom-6" href="/add-location" role="button" data-qa="add-location-button">Add a non-residential location</a>
    {% endif %}

    {{ simplePagination(paginationLocals) }}

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-quarter locations-filter-column">
        <div class="locations-filter" data-qa="locations-filter">
          <form method="get" id="locations-filter-form" data-qa="status-filter-form" class="status-filter">
            {% if hasSelectedFilters %}
              <div class="locations-filter__selected" data-qa="selected-filters">
                <div class="locations-filter__selected-header">
                  <h2 class="govuk-heading-s govuk-!-margin-bottom-0">Selected filters</h2>
                  <a href="{{ clearAllHref }}" class="govuk-link" data-qa="clear-filters-link">Clear filters</a>
                </div>

                {% if statusChips | length %}
                  <h3 class="govuk-heading-s govuk-!-margin-top-3 govuk-!-margin-bottom-2">Location status</h3>
                  <ul class="locations-filter__chip-list" data-qa="selected-status-chips">
                    {% for chip in statusChips %}
                      <li>
                        <a href="{{ chip.removeHref }}" class="locations-filter__chip" data-qa="chip-status-{{ chip.label }}">
                          {{ chip.label }}
                          <span aria-hidden="true">&times;</span>
                          <span class="govuk-visually-hidden">Remove this filter</span>
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}

                {% if serviceChips | length %}
                  <h3 class="govuk-heading-s govuk-!-margin-top-3 govuk-!-margin-bottom-2">Services that use non-residential locations</h3>
                  <ul class="locations-filter__chip-list" data-qa="selected-service-chips">
                    {% for chip in serviceChips %}
                      <li>
                        <a href="{{ chip.removeHref }}" class="locations-filter__chip" data-qa="chip-service-{{ chip.label }}">
                          {{ chip.label }}
                          <span aria-hidden="true">&times;</span>
                          <span class="govuk-visually-hidden">Remove this filter</span>
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>
            {% endif %}

            <fieldset class="govuk-fieldset">
              <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">
                Location status
              </legend>
              <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                <div class="govuk-checkboxes__item">
                  <input class="govuk-checkboxes__input" id="status-ACTIVE" name="status" type="checkbox" value="ACTIVE" {{ "checked" if "ACTIVE" in selectedStatuses }}>
                  <label class="govuk-label govuk-checkboxes__label" for="status-ACTIVE">
                    Active ({{ statusCounts.ACTIVE }})
                  </label>
                </div>
                <div class="govuk-checkboxes__item">
                  <input class="govuk-checkboxes__input" id="status-INACTIVE" name="status" type="checkbox" value="INACTIVE" {{ "checked" if "INACTIVE" in selectedStatuses }}>
                  <label class="govuk-label govuk-checkboxes__label" for="status-INACTIVE">
                    Inactive ({{ statusCounts.INACTIVE }})
                  </label>
                </div>
                <div class="govuk-checkboxes__item">
                  <input class="govuk-checkboxes__input" id="status-ARCHIVED" name="status" type="checkbox" value="ARCHIVED" {{ "checked" if "ARCHIVED" in selectedStatuses }}>
                  <label class="govuk-label govuk-checkboxes__label" for="status-ARCHIVED">
                    Archived ({{ statusCounts.ARCHIVED }})
                  </label>
                </div>
              </div>
            </fieldset>

            <fieldset class="govuk-fieldset govuk-!-margin-top-4">
              <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">
                Services that use non-residential locations
              </legend>
              <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" data-qa="service-filter-checkboxes">
                {% for option in serviceFamilyOptions %}
                  <div class="govuk-checkboxes__item">
                    <input class="govuk-checkboxes__input" id="serviceFamilyType-{{ option.key }}" name="serviceFamilyType" type="checkbox" value="{{ option.key }}" {{ "checked" if option.checked }}>
                    <label class="govuk-label govuk-checkboxes__label" for="serviceFamilyType-{{ option.key }}">
                      {{ option.description }} ({{ option.count }})
                    </label>
                  </div>
                {% endfor %}
              </div>
            </fieldset>

            <div class="locations-filter__actions">
              <button type="submit" class="govuk-button govuk-!-margin-bottom-0" data-qa="apply-filter-button">Apply filters</button>
            </div>
          </form>
        </div>
      </div>

      <div class="govuk-grid-column-three-quarters locations-table-column">
        {% if locations.content | length > 0 %}
          {{ locationsTable(locations.content, paginationLocals, serviceFamilyTypes, canEdit, sort, sortHrefTemplate) }}
        {% else %}
          <p class="govuk-body-l govuk-!-font-weight-bold" data-qa="no-results-heading">There are no matching results.</p>
          <p class="govuk-body" data-qa="no-results-message">Improve your results by applying or removing filters.</p>
        {% endif %}
      </div>
    </div>

    <script nonce="{{ cspNonce }}">
      var form = document.getElementById('locations-filter-form');

      function addNoneStatus() {
        var hidden = document.createElement('input');
        hidden.type = 'hidden';
        hidden.name = 'status';
        hidden.value = 'NONE';
        form.appendChild(hidden);
      }

      form.addEventListener('submit', function() {
        var checkedStatuses = form.querySelectorAll('input[name="status"]:checked');
        if (checkedStatuses.length === 0) {
          addNoneStatus();
        }
      });
    </script>
  </div>
{% endblock %}
